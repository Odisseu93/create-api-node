{
  "name": "create-api-node",
  "version": "0.1.1",
  "description": "Scaffolding CLI for Node + TypeScript APIs (CAN - Create API Node). Choose Express, NestJS, or VkrunJS template; get a ready-to-run project with ESLint, Prettier, and Jest.",
  "author": "Ulisses Silvério/Odisseu93",
  "license": "MIT",
  "repository": "github:Odisseu93/create-api-node",
  "homepage": "https://github.com/Odisseu93/create-api-node#readme",
  "bugs": "https://github.com/Odisseu93/create-api-node/issues",
  "keywords": [
    "cli",
    "scaffolding",
    "node",
    "express",
    "typescript",
    "create-api-node",
    "can",
    "cna"
  ],
  "bin": {
    "create-api-node": "dist/bin/index.js",
    "cna": "dist/bin/index.js"
  },
  "main": "dist/bin/index.js",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/index.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"bin/**/*.ts\" \"core/**/*.ts\" \"steps/**/*.ts\" \"utils/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
